<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="450"
             x:Class="MtgCollectionTracker.Views.ConnectionSettingsView"
             xmlns:vm="clr-namespace:MtgCollectionTracker.ViewModels"
             x:DataType="vm:ConnectionSettingsViewModel">
    <Design.DataContext>
        <vm:ConnectionSettingsViewModel />
    </Design.DataContext>
    <StackPanel Margin="12" Spacing="16">
        <TextBlock FontWeight="Bold" FontSize="14">Connection Settings</TextBlock>
        <TextBlock TextWrapping="Wrap" Foreground="Gray">
            Changes take effect after restarting the application.
        </TextBlock>

        <!-- Mode selection -->
        <StackPanel Spacing="4">
            <TextBlock>Mode</TextBlock>
            <ComboBox SelectedItem="{Binding Mode}" ItemsSource="{Binding Modes}" Width="240" />
        </StackPanel>

        <!-- Remote client settings -->
        <Border IsVisible="{Binding IsRemoteClientMode}" BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="10">
            <StackPanel Spacing="8">
                <TextBlock FontWeight="SemiBold">Remote Server Settings</TextBlock>
                <StackPanel Spacing="4">
                    <TextBlock>Server URL</TextBlock>
                    <TextBox Text="{Binding RemoteServerUrl}" Watermark="http://192.168.1.10:5757" Width="320" HorizontalAlignment="Left" />
                </StackPanel>
                <StackPanel Spacing="4">
                    <TextBlock>API Key</TextBlock>
                    <TextBox Text="{Binding RemoteApiKey}" Watermark="Leave empty if no key is required" Width="320" HorizontalAlignment="Left" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Command="{Binding TestConnectionCommand}" IsEnabled="{Binding !IsTestingConnection}">Test Connection</Button>
                    <TextBlock VerticalAlignment="Center" Text="{Binding ConnectionTestResult}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Server host settings -->
        <Border IsVisible="{Binding IsServerMode}" BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="10">
            <StackPanel Spacing="8">
                <TextBlock FontWeight="SemiBold">Server Host Settings</TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="Gray" FontSize="11">
                    The application will start an embedded sharing server on the configured port.
                    Other devices can connect to this machine using the Remote Client mode.
                </TextBlock>
                <StackPanel Spacing="4">
                    <TextBlock>Port</TextBlock>
                    <NumericUpDown Value="{Binding ServerPort}" Minimum="1024" Maximum="65535" Width="140" HorizontalAlignment="Left" />
                </StackPanel>
                <StackPanel Spacing="4">
                    <TextBlock>API Key (optional)</TextBlock>
                    <TextBox Text="{Binding HostApiKey}" Watermark="Leave empty to allow unauthenticated access" Width="320" HorizontalAlignment="Left" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Button Command="{Binding SaveCommand}">Save Settings</Button>
    </StackPanel>
</UserControl>
