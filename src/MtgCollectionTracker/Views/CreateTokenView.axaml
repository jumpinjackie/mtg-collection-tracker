<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:MtgCollectionTracker.ViewModels"
             mc:Ignorable="d" d:DesignWidth="520" d:DesignHeight="340"
             x:Class="MtgCollectionTracker.Views.CreateTokenView"
             x:DataType="vm:CreateTokenViewModel">
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="10">
        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="Name" FontWeight="Bold" />
            <TextBox Text="{Binding Name}" Watermark="Token name" />
        </StackPanel>

        <StackPanel Grid.Row="1" Spacing="4">
            <TextBlock Text="Oracle Text (optional)" FontWeight="Bold" />
            <TextBox Text="{Binding OracleText}" Watermark="Rules text" AcceptsReturn="True" Height="120" TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="2" Spacing="4">
            <TextBlock Text="P/T" FontWeight="Bold" />
            <TextBox Text="{Binding PowerToughness}" Watermark="e.g. 1/1" />
        </StackPanel>

        <TextBlock Grid.Row="3"
                   Text="{Binding ValidationMessage}"
                   Foreground="Tomato"
                   IsVisible="{Binding ValidationMessage, Converter={x:Static ObjectConverters.IsNotNull}}" />

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,6,0,0">
            <Button Content="Cancel" Command="{Binding CancelCommand}" />
            <Button Content="Create" Command="{Binding CreateCommand}" IsEnabled="{Binding CanCreate}" />
        </StackPanel>
    </Grid>
</UserControl>
