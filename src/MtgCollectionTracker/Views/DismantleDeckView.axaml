<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="clr-namespace:MtgCollectionTracker.ViewModels"
             mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="200"
             x:Class="MtgCollectionTracker.Views.DismantleDeckView"
			 x:DataType="vm:DismantleDeckViewModel">
	<Design.DataContext>
		<!-- This only sets the DataContext for the previewer in an IDE,
         to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
		<vm:DismantleDeckViewModel />
	</Design.DataContext>
	<DockPanel>
		<StackPanel DockPanel.Dock="Bottom" Spacing="10" Margin="10" Orientation="Horizontal">
			<Button Command="{Binding ConfirmCommand}">Yes</Button>
			<Button Command="{Binding CancelCommand}">No</Button>
		</StackPanel>
		<StackPanel Margin="10" Spacing="10">
			<TextBlock Text="{Binding Message}" TextWrapping="WrapWithOverflow" />
			<TextBlock>Send dismantled cards to container:</TextBlock>
			<ComboBox SelectedItem="{Binding SelectedContainer}" ItemsSource="{Binding AvailableContainers}">
				<ComboBox.ItemTemplate>
					<DataTemplate x:DataType="vm:ContainerViewModel">
						<TextBlock Text="{Binding Name}" />
					</DataTemplate>
				</ComboBox.ItemTemplate>
			</ComboBox>
			<TextBlock Foreground="Gray" FontStyle="Italic">Leave blank to send cards to (Unparented)</TextBlock>
		</StackPanel>
	</DockPanel>
</UserControl>
