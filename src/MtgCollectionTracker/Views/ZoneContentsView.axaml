<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:MtgCollectionTracker.ViewModels"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="650"
             x:Class="MtgCollectionTracker.Views.ZoneContentsView"
             x:DataType="vm:ZoneContentsViewModel">
    <!--
        MaxHeight caps the measurement height so that * rows receive a finite constraint even when
        DialogHostAvalonia measures popup content with infinite height. Without this, * rows behave
        like Auto rows, the card preview expands to full image height and button rows are pushed
        off-screen. The initial value (560) is conservative enough for common window sizes; the
        code-behind SizeChanged handler updates it to the actual arranged height so buttons remain
        pinned to the bottom at any window size.
    -->
    <Grid x:Name="RootGrid" RowDefinitions="Auto,*,Auto,Auto" RowSpacing="0" MaxHeight="560">

        <!-- Row 0: Search box + selection count -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,6">
            <TextBox Watermark="Search cards" Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Text="{Binding SelectedCount, StringFormat='Selected: {0} (use Ctrl+Click / Shift+Click to select multiple)'}"
                       FontSize="11" />
        </StackPanel>

        <!-- Row 1: DataGrid + card preview pane. Keep columns flexible so content fits narrow dialog widths. -->
        <Grid Grid.Row="1" ColumnDefinitions="2*,*" ColumnSpacing="8">
            <DataGrid Grid.Column="0"
                      x:Name="CardDataGrid"
                      ItemsSource="{Binding Cards}"
                      SelectedItem="{Binding SelectedCard, Mode=TwoWay}"
                      SelectionMode="Extended"
                      SelectionChanged="OnCardDataGridSelectionChanged"
                      CanUserReorderColumns="False"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="False"
                      GridLinesVisibility="Horizontal"
                      IsReadOnly="True"
                      BorderThickness="1">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Card Name" Binding="{Binding CardName}" Width="*" />
                    <DataGridTextColumn Header="Mana Cost" Binding="{Binding ManaCost}" Width="Auto" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- Card preview (right pane) -->
            <Border Grid.Column="1" MinWidth="220" MaxWidth="450" Padding="12" Background="{DynamicResource SystemChromeLowColor}">
                <ScrollViewer>
                    <StackPanel DataContext="{Binding SelectedCard}"
                                Spacing="8"
                                IsVisible="{Binding ., Converter={x:Static ObjectConverters.IsNotNull}}">
                        <TextBlock Text="{Binding CardName}"
                                   FontSize="16" FontWeight="Bold" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding ManaCost}" FontSize="14" />
                        <TextBlock Text="{Binding CardType}" FontSize="12" TextWrapping="Wrap" Opacity="0.9" />
                        <TextBlock Text="{Binding OracleText}" FontSize="11" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding PT}" FontSize="13" FontWeight="Bold"
                                   IsVisible="{Binding PT, Converter={x:Static ObjectConverters.IsNotNull}}" />
                        <Image Source="{Binding CardImageLarge^}" Stretch="Uniform" MaxHeight="400" Margin="0,8,0,0" />
                    </StackPanel>
                </ScrollViewer>
                <Border.IsVisible>
                    <Binding Path="SelectedCard" Converter="{x:Static ObjectConverters.IsNotNull}" />
                </Border.IsVisible>
            </Border>

            <TextBlock Grid.Column="1" Text="Select a card to view details"
                       Opacity="0.6" VerticalAlignment="Center" HorizontalAlignment="Center"
                       IsVisible="{Binding SelectedCard, Converter={x:Static ObjectConverters.IsNull}}" />
        </Grid>

        <!-- Row 2: Separator -->
        <Border Grid.Row="2" Height="1" Background="{DynamicResource SystemChromeLowColor}" Margin="0,8,0,8" />

        <!-- Row 3: Action buttons – left-aligned so they start at the left edge and never overflow off the right -->
        <WrapPanel Grid.Row="3" HorizontalAlignment="Left" ItemSpacing="6" LineSpacing="6" Margin="0,0,0,4">
            <CheckBox Content="Shuffle library after closing"
                      IsChecked="{Binding ShuffleAfterClose}"
                      IsVisible="{Binding ShowShuffleOption}" />
            <Button Content="Put onto battlefield" Command="{Binding MoveToBattlefieldCommand}" IsVisible="{Binding ShowMoveToBattlefield}" />
            <Button Content="Put into hand" Command="{Binding MoveToHandCommand}" IsVisible="{Binding ShowMoveToHand}" />
            <Button Content="Put into graveyard" Command="{Binding MoveToGraveyardCommand}" IsVisible="{Binding ShowMoveToGraveyard}" />
            <Button Content="Put into exile" Command="{Binding MoveToExileCommand}" IsVisible="{Binding ShowMoveToExile}" />
            <Button Content="Close" Command="{Binding CloseCommand}" />
        </WrapPanel>
    </Grid>
</UserControl>
