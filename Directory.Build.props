<Project>
  <PropertyGroup>
    <Nullable>enable</Nullable>
    <AvaloniaVersion>12.0.0</AvaloniaVersion>
    <!-- When built in CI, bake the full commit SHA into AssemblyInformationalVersion as +<sha> build metadata -->
    <SourceRevisionId Condition="'$(COMMIT_SHA)' != ''">$(COMMIT_SHA)</SourceRevisionId>
  </PropertyGroup>
</Project>
